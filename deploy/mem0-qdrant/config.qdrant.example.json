{
  "version": "v1.1",
  "vector_store": {
    "provider": "qdrant",
    "config": {
      "host": "qdrant",
      "port": 6333,
      "collection_name": "mem0"
    }
  },
  "llm": {
    "provider": "openai",
    "config": {
      "model": "gpt-4.1-nano-2025-04-14",
      "temperature": 0.2,
      "api_key": "${OPENAI_API_KEY}"
    }
  },
  "embedder": {
    "provider": "openai",
    "config": {
      "model": "text-embedding-3-small",
      "api_key": "${OPENAI_API_KEY}"
    }
  }
}
