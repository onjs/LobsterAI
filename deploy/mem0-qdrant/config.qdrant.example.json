{
  "version": "v1.1",
  "vector_store": {
    "provider": "qdrant",
    "config": {
      "host": "qdrant",
      "port": 6333,
      "collection_name": "mem0"
    }
  },
  "llm": {
    "provider": "minimax",
    "config": {
      "model": "MiniMax-M2.7",
      "temperature": 0.2,
      "api_key": "${MINIMAX_API_KEY}",
      "minimax_base_url": "${MINIMAX_API_BASE}"
    }
  },
  "embedder": {
    "provider": "openai",
    "config": {
      "model": "${MEM0_EMBEDDER_MODEL}",
      "api_key": "${MINIMAX_API_KEY}",
      "openai_base_url": "${MINIMAX_API_BASE}"
    }
  }
}
