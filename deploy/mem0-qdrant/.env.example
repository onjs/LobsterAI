# -----------------------------
# Mem0 REST endpoint
# -----------------------------
MEM0_BASE_URL=http://localhost:8888
MEM0_API_KEY=

# Optional: protect mem0 REST endpoints (server-side)
ADMIN_API_KEY=

# -----------------------------
# Shared model key (used by mem0 server defaults)
# -----------------------------
OPENAI_API_KEY=

# -----------------------------
# Qdrant
# -----------------------------
# In docker-compose network use `qdrant`; from host use `localhost`
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_BASE_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=mem0

# -----------------------------
# mem0 /configure payload (LLM + Embedder)
# -----------------------------
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=gpt-4.1-nano-2025-04-14
MEM0_LLM_API_KEY=

MEM0_EMBEDDER_PROVIDER=openai
MEM0_EMBEDDER_MODEL=text-embedding-3-small
MEM0_EMBEDDER_API_KEY=

# Optional: custom config json path
# MEM0_CONFIG_FILE=deploy/mem0-qdrant/config.qdrant.json
