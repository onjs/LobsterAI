# -----------------------------
# Mem0 REST endpoint
# -----------------------------
MEM0_BASE_URL=http://localhost:8888
MEM0_API_KEY=

# Optional: protect mem0 REST endpoints (server-side)
ADMIN_API_KEY=

# -----------------------------
# Model keys
# -----------------------------
# OpenAI-compatible mode (recommended):
# - If using MiniMax compatibility API, put your MiniMax key into OPENAI_API_KEY
# - Set OPENAI_BASE_URL to MiniMax OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.minimax.io/v1

# Optional MiniMax aliases (fallback only)
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# -----------------------------
# Qdrant
# -----------------------------
# In docker-compose network use `qdrant`; from host use `localhost`
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_BASE_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=mem0

# -----------------------------
# mem0 /configure payload (LLM + Embedder)
# -----------------------------
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=MiniMax-M2.7
MEM0_LLM_API_KEY=
MEM0_LLM_MINIMAX_BASE_URL=
MEM0_LLM_OPENAI_BASE_URL=

MEM0_EMBEDDER_PROVIDER=openai
MEM0_EMBEDDER_MODEL=text-embedding-3-small
MEM0_EMBEDDER_API_KEY=
MEM0_EMBEDDER_OPENAI_BASE_URL=

# Optional: custom config json path
# MEM0_CONFIG_FILE=deploy/mem0-qdrant/config.qdrant.json
